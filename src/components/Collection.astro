---
import { siteConfig } from "../config";
---

<section id="collection" class="py-20 md:py-28 bg-transparent">
  <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
    <h2
      class="font-serif uppercase tracking-[0.25em] text-2xl md:text-3xl"
      style={`color: ${siteConfig.highlightColor}; font-weight: 500;`}
    >
      Art Collection
    </h2>
    <p
      class="mt-2 text-xs uppercase"
      style={`color: ${siteConfig.accentColor}80; letter-spacing: 0.3em;`}
    >
      Olga Torres · {siteConfig.heroBrand}
    </p>
    <div
      class="mx-auto mt-6 h-px w-16"
      style={`background-color: ${siteConfig.accentColor}30`}
    ></div>

    <div class="mt-12 reveal">
      <img
        src={`${import.meta.env.BASE_URL}assets/collection-grid.jpeg`}
        alt="Art Collection — No Mires Atrás, El Río Suena, Mar y Tierra, Gente Urbana, Sole, Miradas Tristes"
        class="w-full h-auto mx-auto"
        loading="lazy"
      />
    </div>

    <p
      class="mt-12 font-serif italic text-base md:text-lg"
      style={`color: ${siteConfig.accentColor}99`}
    >
      Cada obra nace de una emoción. Cada color, de un instante vivido.
    </p>
  </div>
</section>
