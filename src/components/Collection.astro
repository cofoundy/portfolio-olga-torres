---
import { siteConfig } from "../config";
---

<section id="collection" class="py-20 md:py-28 bg-transparent">
  <div class="max-w-5xl mx-auto px-6 lg:px-8 text-center">
    <h2
      class="font-serif uppercase tracking-[0.25em] text-2xl md:text-3xl"
      style={`color: ${siteConfig.highlightColor}; font-weight: 500;`}
    >
      Art Collection
    </h2>
    <p
      class="mt-2 text-xs uppercase"
      style={`color: ${siteConfig.accentColor}80; letter-spacing: 0.3em;`}
    >
      {siteConfig.heroBrand}
    </p>
    <div
      class="mx-auto mt-6 h-px w-16"
      style={`background-color: ${siteConfig.accentColor}30`}
    ></div>

    <div class="mt-16 grid grid-cols-2 md:grid-cols-3 gap-8 md:gap-12">
      {siteConfig.collection.map((piece, i) => (
        <div class={`reveal stagger-${(i % 5) + 1} text-center`}>
          <div
            class="aspect-square w-full card-hover"
            style={`background: linear-gradient(135deg, ${piece.palette[0]} 0%, ${piece.palette[1]} 55%, ${piece.palette[2]} 100%); filter: saturate(0.85);`}
          ></div>
          <p
            class="mt-4 font-serif text-base md:text-lg"
            style={`color: ${siteConfig.accentColor}`}
          >
            {piece.name}
          </p>
        </div>
      ))}
    </div>

    <p
      class="mt-16 font-serif italic text-base md:text-lg"
      style={`color: ${siteConfig.accentColor}99`}
    >
      Cada obra nace de una emoción. Cada color, de un instante vivido.
    </p>
  </div>
</section>
