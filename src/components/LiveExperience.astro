---
import { siteConfig } from "../config";

const steps = siteConfig.experience4.map((s, i) => ({
  ...s,
  slug: ["movimiento", "emocion", "catarsis", "arte"][i],
}));
---

<section id="experience" class="py-20 md:py-28 bg-transparent">
  <div class="max-w-5xl mx-auto px-6 lg:px-8">
    <div class="text-center">
      <h2
        class="font-serif uppercase tracking-[0.25em] text-2xl md:text-3xl"
        style={`color: ${siteConfig.accentColor}; font-weight: 500;`}
      >
        Live the Experience
      </h2>
      <div
        class="mx-auto mt-6 h-px w-16"
        style={`background-color: ${siteConfig.accentColor}20`}
      ></div>
    </div>

    <!-- Tabs -->
    <div class="mt-12 flex flex-wrap justify-center gap-10 md:gap-16 font-serif italic text-base md:text-lg border-b"
         style={`border-color: ${siteConfig.accentColor}15;`}>
      {steps.map((s, i) => (
        <button
          data-tab={s.slug}
          class={`exp-tab pb-3 transition-colors ${i === 0 ? "active" : ""}`}
          style={`color: ${siteConfig.accentColor}`}
        >
          {s.title.charAt(0) + s.title.slice(1).toLowerCase()}
        </button>
      ))}
    </div>

    <!-- Panels -->
    <div class="mt-12">
      {steps.map((s, i) => (
        <div
          data-panel={s.slug}
          class={`exp-panel grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center ${i === 0 ? "" : "hidden"}`}
        >
          <div>
            <img
              src={`${import.meta.env.BASE_URL}assets/exp-${s.slug}.jpeg`}
              alt={s.title}
              class="w-full h-auto"
              loading="lazy"
            />
          </div>
          <div class="text-center md:text-left">
            <h3
              class="font-serif text-3xl md:text-4xl"
              style={`color: ${siteConfig.accentColor}; letter-spacing: 0.02em;`}
            >
              {s.title}
            </h3>
            <p
              class="mt-5 font-serif italic text-xl md:text-2xl leading-snug"
              style={`color: ${siteConfig.accentColor}`}
            >
              {s.quote}
            </p>
            <div
              class="mt-5 mx-auto md:mx-0 h-px w-16"
              style={`background-color: ${siteConfig.accentColor}25`}
            ></div>
            <p
              class="mt-5 text-base leading-relaxed"
              style={`color: ${siteConfig.accentColor}CC`}
            >
              {s.text}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style define:vars={{ gold: siteConfig.highlightColor }}>
  .exp-tab { position: relative; color: var(--accent); }
  .exp-tab.active { color: var(--gold); }
  .exp-tab.active::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background-color: var(--gold);
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".exp-tab");
  const panels = document.querySelectorAll<HTMLElement>(".exp-panel");
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const slug = tab.dataset.tab;
      tabs.forEach((t) => t.classList.toggle("active", t === tab));
      panels.forEach((p) => p.classList.toggle("hidden", p.dataset.panel !== slug));
    });
  });
</script>
