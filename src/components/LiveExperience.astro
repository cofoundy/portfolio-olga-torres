---
import { siteConfig } from "../config";
---

<section id="experience" class="py-20 md:py-28 bg-transparent">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 text-center">
    <h2
      class="font-serif uppercase tracking-[0.25em] text-2xl md:text-3xl"
      style={`color: ${siteConfig.accentColor}; font-weight: 500;`}
    >
      Live the Experience
    </h2>
    <div
      class="mx-auto mt-6 h-px w-16"
      style={`background-color: ${siteConfig.highlightColor}`}
    ></div>

    <div class="mt-12 reveal">
      <img
        src={`${import.meta.env.BASE_URL}assets/experience-final.jpeg`}
        alt="Live the Experience — Movimiento, Emoción, Catarsis, Arte"
        class="w-full h-auto mx-auto max-w-5xl"
        loading="lazy"
      />
    </div>
  </div>
</section>
