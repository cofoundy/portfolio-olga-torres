---
import { siteConfig } from "../config";
---

<section id="experience" class="py-20 md:py-28 bg-transparent">
  <div class="max-w-6xl mx-auto px-6 lg:px-8 text-center">
    <h2
      class="font-serif uppercase tracking-[0.25em] text-2xl md:text-3xl"
      style={`color: ${siteConfig.accentColor}; font-weight: 500;`}
    >
      Live the Experience
    </h2>
    <div
      class="mx-auto mt-6 h-px w-16"
      style={`background-color: ${siteConfig.highlightColor}`}
    ></div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-8 text-left">
      {siteConfig.experience4.map((step, i) => (
        <div class={`reveal stagger-${i + 1}`}>
          <div
            class="aspect-[4/5] w-full mb-6"
            style={`background: linear-gradient(180deg, ${siteConfig.highlightColor}15, ${siteConfig.accentColor}10); filter: blur(0.3px);`}
          ></div>
          <h3
            class="font-serif uppercase tracking-[0.15em] text-sm md:text-base"
            style={`color: ${siteConfig.accentColor}; font-weight: 600;`}
          >
            {step.title}
          </h3>
          <div
            class="mt-2 h-px w-10"
            style={`background-color: ${siteConfig.highlightColor}`}
          ></div>
          <p
            class="mt-3 font-serif italic text-base md:text-lg leading-snug"
            style={`color: ${siteConfig.accentColor}`}
          >
            {step.quote}
          </p>
          <p
            class="mt-3 text-sm leading-relaxed"
            style={`color: ${siteConfig.accentColor}BB`}
          >
            {step.text}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
