---
import { siteConfig } from "../config";
---

<section id="hero" class="relative pt-24 pb-16 md:pt-32 md:pb-24 bg-transparent">
  <div class="max-w-5xl mx-auto px-6 lg:px-8 text-center">

    <h1
      class="hero-title font-serif tracking-[0.08em] text-5xl sm:text-6xl md:text-7xl lg:text-8xl"
      style={`color: ${siteConfig.highlightColor}; font-weight: 500;`}
    >
      {siteConfig.heroTitle}
    </h1>

    <p
      class="hero-subtitle font-serif mt-4 text-2xl md:text-3xl"
      style={`color: ${siteConfig.accentColor}; letter-spacing: 0.05em;`}
    >
      {siteConfig.heroSubtitle}
    </p>

    <p
      class="hero-description mt-2 text-xs md:text-sm uppercase"
      style={`color: ${siteConfig.accentColor}99; letter-spacing: 0.3em;`}
    >
      {siteConfig.heroBrand}
    </p>

    <div
      class="mx-auto mt-10 h-px w-24"
      style={`background-color: ${siteConfig.accentColor}30`}
    ></div>

    <p
      class="hero-cta mt-10 font-serif text-3xl md:text-4xl lg:text-5xl"
      style={`color: ${siteConfig.accentColor};`}
    >
      {siteConfig.heroQuote}
      <br />
      <em style={`color: ${siteConfig.highlightColor}`}>{siteConfig.heroQuoteItalic}</em>
    </p>

    <p
      class="hero-social mt-12 text-xs md:text-sm uppercase"
      style={`color: ${siteConfig.highlightColor}; letter-spacing: 0.35em;`}
    >
      {siteConfig.heroMotif}
    </p>

    <div class="hero-stats mt-14 flex flex-wrap justify-center gap-6 md:gap-10 text-sm md:text-base font-serif italic">
      <a href="#collection" class="link-underline" style={`color: ${siteConfig.accentColor}`}>Art Collection</a>
      <span style={`color: ${siteConfig.accentColor}40`}>|</span>
      <a href="#experience" class="link-underline" style={`color: ${siteConfig.highlightColor}`}>Live the Experience</a>
      <span style={`color: ${siteConfig.accentColor}40`}>|</span>
      <a href="#wear" class="link-underline" style={`color: ${siteConfig.accentColor}`}>Wear the Art</a>
    </div>
  </div>
</section>
