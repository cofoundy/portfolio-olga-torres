---
import { siteConfig } from "../config";
---

<section id="workshop" class="py-20 md:py-28 bg-transparent">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center">
      <h2
        class="font-serif uppercase tracking-[0.25em] text-2xl md:text-3xl"
        style={`color: ${siteConfig.highlightColor}; font-weight: 500;`}
      >
        Soul Paint Workshop
      </h2>
      <p
        class="mt-2 text-xs uppercase"
        style={`color: ${siteConfig.accentColor}80; letter-spacing: 0.3em;`}
      >
        Olga Torres · Valiente Huella
      </p>
      <div
        class="mx-auto mt-6 h-px w-16"
        style={`background-color: ${siteConfig.accentColor}20`}
      ></div>
      <p
        class="mt-8 font-serif italic text-2xl md:text-3xl"
        style={`color: ${siteConfig.accentColor}`}
      >
        {siteConfig.workshopTagline}
      </p>
    </div>

    <!-- Objetivos (2-col: foto + lista) -->
    <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
      <div class="reveal-left order-2 md:order-1">
        <h3
          class="font-serif text-3xl md:text-4xl mb-8"
          style={`color: ${siteConfig.accentColor};`}
        >
          Objetivos
        </h3>
        <ul class="space-y-5">
          {siteConfig.workshopObjectives.map((obj) => (
            <li class="flex gap-4">
              <span
                class="mt-2 flex-shrink-0 h-px w-6"
                style={`background-color: ${siteConfig.highlightColor}`}
              ></span>
              <p class="text-sm md:text-base leading-relaxed" style={`color: ${siteConfig.accentColor}CC`}>
                {obj}
              </p>
            </li>
          ))}
        </ul>
      </div>
      <div class="reveal-right order-1 md:order-2">
        <img
          src={`${import.meta.env.BASE_URL}assets/workshop-hero.jpeg`}
          alt="Soul Paint Workshop"
          class="w-full h-auto"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Cómo funciona + La Catarsis -->
    <div class="mt-24 md:mt-32 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
      <div class="reveal-left">
        <img
          src={`${import.meta.env.BASE_URL}assets/workshop-process.jpeg`}
          alt="Cómo funciona Soul Paint"
          class="w-full h-auto"
          loading="lazy"
        />
      </div>
      <div class="reveal-right">
        <h3
          class="font-serif text-3xl md:text-4xl"
          style={`color: ${siteConfig.accentColor};`}
        >
          {siteConfig.workshopHow.title}
        </h3>
        <div
          class="mt-4 h-px w-16"
          style={`background-color: ${siteConfig.highlightColor}`}
        ></div>
        <p class="mt-6 text-base leading-relaxed" style={`color: ${siteConfig.accentColor}CC`}>
          {siteConfig.workshopHow.intro}
        </p>
        <p class="mt-6 font-serif italic text-lg md:text-xl" style={`color: ${siteConfig.highlightColor}`}>
          La Catarsis
        </p>
        <p class="mt-3 text-base leading-relaxed" style={`color: ${siteConfig.accentColor}CC`}>
          {siteConfig.workshopHow.catarsis}
        </p>
      </div>
    </div>

    <!-- Por qué funciona (4 pilares) -->
    <div class="mt-24 md:mt-32 text-center">
      <h3
        class="font-serif uppercase tracking-[0.25em] text-xl md:text-2xl"
        style={`color: ${siteConfig.accentColor}; font-weight: 500;`}
      >
        Por qué funciona
      </h3>
      <div
        class="mx-auto mt-6 h-px w-16"
        style={`background-color: ${siteConfig.highlightColor}`}
      ></div>
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-10 text-left">
        {siteConfig.workshopWhy.map((pillar, i) => (
          <div class={`reveal stagger-${(i % 4) + 1}`}>
            <p
              class="font-serif text-xl md:text-2xl"
              style={`color: ${siteConfig.highlightColor}`}
            >
              {i + 1}. {pillar.title}
            </p>
            <p class="mt-3 text-sm md:text-base leading-relaxed" style={`color: ${siteConfig.accentColor}CC`}>
              {pillar.text}
            </p>
          </div>
        ))}
      </div>
    </div>

    <!-- Los Cursos -->
    <div class="mt-24 md:mt-32 text-center">
      <h3
        class="font-serif uppercase tracking-[0.25em] text-xl md:text-2xl"
        style={`color: ${siteConfig.highlightColor}; font-weight: 500;`}
      >
        Los Cursos
      </h3>
      <div
        class="mx-auto mt-6 h-px w-16"
        style={`background-color: ${siteConfig.accentColor}20`}
      ></div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 text-left">
        {siteConfig.workshops.map((course, i) => (
          <div
            class={`reveal stagger-${(i % 5) + 1} p-7 card-hover`}
            style={`background-color: rgba(255,255,255,0.4); border: 1px solid ${siteConfig.accentColor}15;`}
          >
            <p
              class="font-serif text-xl md:text-2xl"
              style={`color: ${siteConfig.accentColor}`}
            >
              {course.name}
            </p>
            <p class="mt-1 text-xs uppercase" style={`color: ${siteConfig.highlightColor}; letter-spacing: 0.15em;`}>
              {course.meta}
            </p>
            <div
              class="mt-4 h-px w-10"
              style={`background-color: ${siteConfig.highlightColor}`}
            ></div>
            <p class="mt-4 text-sm leading-relaxed" style={`color: ${siteConfig.accentColor}CC`}>
              {course.description}
            </p>
            <p class="mt-6 font-serif text-2xl" style={`color: ${siteConfig.highlightColor}`}>
              {course.price}
            </p>
            <p class="mt-1 text-xs italic" style={`color: ${siteConfig.accentColor}88`}>
              {course.priceNote}
            </p>
          </div>
        ))}
      </div>

      <p class="mt-12 font-serif italic text-sm md:text-base" style={`color: ${siteConfig.accentColor}99`}>
        Grupos reducidos de máximo 8 personas · Coaching individual disponible
      </p>

      <!-- CTA -->
      <div class="mt-10 flex flex-wrap justify-center gap-5">
        <a
          href={siteConfig.social.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block pb-1 font-serif italic text-base border-b link-underline"
          style={`color: ${siteConfig.highlightColor}; border-color: ${siteConfig.highlightColor}`}
        >
          Reserva tu sesión por WhatsApp →
        </a>
        <a
          href={`mailto:${siteConfig.social.email}`}
          class="inline-block pb-1 font-serif italic text-base border-b link-underline"
          style={`color: ${siteConfig.accentColor}; border-color: ${siteConfig.accentColor}40`}
        >
          valientehuella@gmail.com
        </a>
      </div>
    </div>
  </div>
</section>
