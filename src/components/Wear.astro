---
import { siteConfig } from "../config";
---

<section id="wear" class="py-20 md:py-28 bg-transparent">
  <div class="max-w-5xl mx-auto px-6 lg:px-8 text-center">
    <h2
      class="font-serif uppercase tracking-[0.25em] text-2xl md:text-3xl"
      style={`color: ${siteConfig.highlightColor}; font-weight: 500;`}
    >
      Wear the Art
    </h2>
    <p
      class="mt-2 text-xs uppercase"
      style={`color: ${siteConfig.accentColor}80; letter-spacing: 0.3em;`}
    >
      Olga Torres · {siteConfig.heroBrand}
    </p>
    <div
      class="mx-auto mt-6 h-px w-16"
      style={`background-color: ${siteConfig.accentColor}20`}
    ></div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-14">
      {siteConfig.wear.map((item, i) => (
        <div class={`reveal stagger-${i + 1} text-center`}>
          <div class="aspect-[3/4] w-full flex items-center justify-center overflow-hidden">
            <img
              src={`${import.meta.env.BASE_URL}assets/${item.image}`}
              alt={item.name}
              class="w-full h-full object-contain card-hover"
              loading="lazy"
            />
          </div>
          <p
            class="mt-6 font-serif uppercase tracking-[0.18em] text-sm md:text-base"
            style={`color: ${siteConfig.accentColor}; font-weight: 600;`}
          >
            {item.name}
          </p>
          <p
            class="mt-1 text-xs"
            style={`color: ${siteConfig.accentColor}88`}
          >
            {item.type}
          </p>
          <p
            class="mt-3 font-serif text-base"
            style={`color: ${siteConfig.highlightColor}`}
          >
            {item.price}
          </p>
        </div>
      ))}
    </div>

    <p
      class="mt-16 font-serif italic text-sm"
      style={`color: ${siteConfig.accentColor}99`}
    >
      Valiente Huella by Olga Torres
    </p>
    <p
      class="mt-2 text-xs uppercase"
      style={`color: ${siteConfig.highlightColor}; letter-spacing: 0.35em;`}
    >
      Art · Emotion · Ritual
    </p>
  </div>
</section>
