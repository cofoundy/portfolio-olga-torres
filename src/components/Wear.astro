---
import { siteConfig } from "../config";
---

<section id="wear" class="py-20 md:py-28 bg-transparent">
  <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
    <h2
      class="font-serif uppercase tracking-[0.25em] text-2xl md:text-3xl"
      style={`color: ${siteConfig.highlightColor}; font-weight: 500;`}
    >
      Wear the Art
    </h2>
    <p
      class="mt-2 text-xs uppercase"
      style={`color: ${siteConfig.accentColor}80; letter-spacing: 0.3em;`}
    >
      Olga Torres · {siteConfig.heroBrand}
    </p>
    <div
      class="mx-auto mt-6 h-px w-16"
      style={`background-color: ${siteConfig.accentColor}30`}
    ></div>

    <div class="mt-12 reveal">
      <img
        src={`${import.meta.env.BASE_URL}assets/wear-mockup.jpeg`}
        alt="Wear the Art — No Mires Atrás, Todo Te Ve, Flor de Mayo"
        class="w-full h-auto mx-auto"
        loading="lazy"
      />
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-10 text-center">
      {siteConfig.wear.map((item) => (
        <div>
          <p
            class="font-serif uppercase tracking-[0.18em] text-sm md:text-base"
            style={`color: ${siteConfig.accentColor}; font-weight: 600;`}
          >
            {item.name}
          </p>
          <p
            class="mt-1 text-xs"
            style={`color: ${siteConfig.accentColor}88`}
          >
            {item.type}
          </p>
          <p
            class="mt-2 font-serif text-base"
            style={`color: ${siteConfig.highlightColor}`}
          >
            {item.price}
          </p>
        </div>
      ))}
    </div>

    <p
      class="mt-12 font-serif italic text-base"
      style={`color: ${siteConfig.accentColor}99`}
    >
      Art · Emotion · Ritual
    </p>
  </div>
</section>
